module signal_monitor_top (
  clk,
  rst_n,
  start_n,
  uart_tx,
  led
)
;
input clk;
input rst_n;
input start_n;
output uart_tx;
output [5:0] led;
wire clk_d;
wire rst_n_d;
wire start_n_d;
wire n5_6;
wire clk_proc;
wire pll_locked;
wire start_pulse;
wire n7_5;
wire uart_tx_d;
wire [5:0] led_d;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF rst_n_ibuf (
    .O(rst_n_d),
    .I(rst_n) 
);
  IBUF start_n_ibuf (
    .O(start_n_d),
    .I(start_n) 
);
  OBUF uart_tx_obuf (
    .O(uart_tx),
    .I(uart_tx_d) 
);
  OBUF led_0_obuf (
    .O(led[0]),
    .I(led_d[0]) 
);
  OBUF led_1_obuf (
    .O(led[1]),
    .I(led_d[1]) 
);
  OBUF led_2_obuf (
    .O(led[2]),
    .I(led_d[2]) 
);
  OBUF led_3_obuf (
    .O(led[3]),
    .I(led_d[3]) 
);
  OBUF led_4_obuf (
    .O(led[4]),
    .I(led_d[4]) 
);
  OBUF led_5_obuf (
    .O(led[5]),
    .I(led_d[5]) 
);
  INV n5_s2 (
    .O(n5_6),
    .I(rst_n_d) 
);
  pll_54mhz pll_54mhz_inst (
    .clk_d(clk_d),
    .n5_6(n5_6),
    .clk_proc(clk_proc),
    .pll_locked(pll_locked)
);
  button_debounce start_button_debounce (
    .clk_proc(clk_proc),
    .start_n_d(start_n_d),
    .rst_n_d(rst_n_d),
    .pll_locked(pll_locked),
    .start_pulse(start_pulse),
    .n7_5(n7_5)
);
  signal_monitor_core signal_monitor_core_inst (
    .clk_proc(clk_proc),
    .n7_5(n7_5),
    .start_pulse(start_pulse),
    .uart_tx_d(uart_tx_d),
    .led_d(led_d[5:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* signal_monitor_top */
